{
  "name": "kanri",
  "version": "1.0.0",
  "description": "Sistema de gestión de inventario para laboratorio de cómputo.",
  "main": "src/main/main.js",
  "author": "VICTORONJA-MN",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --no-sandbox",
    "pack:win": "electron-builder --win portable",
    "pack:linux": "electron-builder --linux AppImage",
    "pack:dir": "electron-builder --dir"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.victoronja.kanri",
    "productName": "Kanri",
    "copyright": "MIT © VICTORONJA-MN",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "assets/**",
      "package.json"
    ],
    "npmRebuild": false,
    "asar": true,
    "icon": "assets/icon",
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}